<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gerador de Mensagem - Holyrics</title>
    <style>
        body {
            font-family: system-ui, -apple-system, sans-serif;
            background-color: #f4f4f9;
            color: #333;
            max-width: 800px;
            margin: 0 auto;
            padding: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        .header h1 {
            color: #2c3e50;
        }

        .slide-container {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 2px 5px rgba(0,0,0,0.1);
            margin-bottom: 15px;
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .slide-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-weight: bold;
            color: #7f8c8d;
        }

        textarea {
            width: 100%;
            height: 100px;
            padding: 10px;
            border: 1px solid #bdc3c7;
            border-radius: 4px;
            resize: vertical;
            font-size: 16px;
            box-sizing: border-box;
            font-family: inherit;
        }

        .btn {
            padding: 10px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            font-weight: bold;
            transition: opacity 0.2s;
        }

        .btn:hover {
            opacity: 0.8;
        }

        .btn-add {
            background-color: #27ae60;
            color: white;
            margin-bottom: 20px;
        }

        .btn-remove {
            background-color: #e74c3c;
            color: white;
            padding: 5px 10px;
            font-size: 12px;
        }

        .btn-export {
            background-color: #2980b9;
            color: white;
            width: 100%;
            font-size: 18px;
            padding: 15px;
            margin-top: 10px;
        }
    </style>
</head>
<body>

    <div class="header">
        <h1>Gerador de Slides Holyrics</h1>
        <p>Monte os textos dos slides abaixo. Ao exportar, o arquivo já sairá no formato para importar no Holyrics.</p>
    </div>

    <button class="btn btn-add" onclick="adicionarSlide()">+ Adicionar Novo Slide</button>

    <div id="lista-slides">
        <div class="slide-container">
            <div class="slide-header">
                <span>Slide 1</span>
            </div>
            <textarea placeholder="Digite o texto deste slide aqui..."></textarea>
        </div>
    </div>

    <button class="btn btn-export" onclick="exportarParaHolyrics()">📥 Baixar Arquivo para Holyrics</button>

    <script>
        let contadorSlides = 1;

        function adicionarSlide() {
            contadorSlides++;
            const lista = document.getElementById('lista-slides');
            
            const novoSlide = document.createElement('div');
            novoSlide.className = 'slide-container';
            
            novoSlide.innerHTML = `
                <div class="slide-header">
                    <span class="slide-numero">Slide ${contadorSlides}</span>
                    <button class="btn btn-remove" onclick="removerSlide(this)">Remover</button>
                </div>
                <textarea placeholder="Digite o texto deste slide aqui..."></textarea>
            `;
            
            lista.appendChild(novoSlide);
            atualizarNumeracao();
        }

        function removerSlide(botao) {
            const slide = botao.closest('.slide-container');
            slide.remove();
            atualizarNumeracao();
        }

        function atualizarNumeracao() {
            const slides = document.querySelectorAll('.slide-container');
            slides.forEach((slide, index) => {
                const numeroSpan = slide.querySelector('.slide-header span');
                numeroSpan.textContent = `Slide ${index + 1}`;
            });
            contadorSlides = slides.length;
        }

        function exportarParaHolyrics() {
            const caixasTexto = document.querySelectorAll('textarea');
            let textos = [];

            caixasTexto.forEach(caixa => {
                const conteudo = caixa.value.trim();
                // Só adiciona se o slide não estiver vazio
                if (conteudo !== '') {
                    textos.push(conteudo);
                }
            });

            if (textos.length === 0) {
                alert("Por favor, digite algum texto antes de exportar.");
                return;
            }

            // Une os textos usando DUAS quebras de linha (\n\n)
            // Esse é o padrão que o Holyrics entende para dividir blocos de texto
            const textoFinal = textos.join('\n\n');

            // Cria o arquivo virtual para download
            const blob = new Blob([textoFinal], { type: 'text/plain;charset=utf-8' });
            const url = URL.createObjectURL(blob);
            
            // Cria um link invisível e clica nele para baixar
            const link = document.createElement('a');
            link.href = url;
            link.download = 'Mensagem_Culto_Holyrics.txt';
            document.body.appendChild(link);
            link.click();
            
            // Limpeza
            document.body.removeChild(link);
            URL.revokeObjectURL(url);
        }
    </script>
</body>
</html>
